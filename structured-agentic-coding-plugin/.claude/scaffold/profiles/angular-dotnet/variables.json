{
  "profile": "angular-dotnet",
  "scope": "fullstack",
  "context_hints": [
    {
      "file": "nx.json",
      "grep": ".",
      "implies": { "NX_MONOREPO": "true" }
    },
    {
      "file": "README.md",
      "grep": "(?i)nx monorepo|nx workspace",
      "implies": { "NX_MONOREPO": "true" }
    },
    {
      "file": "README.md",
      "grep": "(?i)entity framework|ef core",
      "implies": { "ORM": "ef-core" }
    }
  ],
  "variables": [
    {
      "key": "FE_DIR",
      "label": "Frontend directory",
      "scope": "fe",
      "required": true,
      "default": "frontend",
      "detect": [
        { "type": "glob-first-path", "pattern": "frontend/package.json" },
        { "type": "glob-first-path", "pattern": "apps/*/package.json" }
      ]
    },
    {
      "key": "BE_DIR",
      "label": "Backend directory",
      "scope": "be",
      "required": true,
      "default": "backend",
      "detect": [
        { "type": "glob-first-path", "pattern": "backend" },
        { "type": "glob-first-path", "pattern": "apps/api" }
      ]
    },
    {
      "key": "FE_SERVE",
      "label": "Frontend dev server command",
      "scope": "fe",
      "detect": [
        { "type": "package-json-script", "script": "serve" },
        { "type": "package-json-script", "script": "start" },
        { "type": "package-json-script", "script": "dev" },
        { "type": "static", "value": "npx nx serve" }
      ]
    },
    {
      "key": "FE_BUILD",
      "label": "Frontend build command",
      "scope": "fe",
      "detect": [
        { "type": "package-json-script", "script": "build" },
        { "type": "static", "value": "npm run build" }
      ]
    },
    {
      "key": "FE_TEST",
      "label": "Frontend test command",
      "scope": "fe",
      "detect": [
        { "type": "package-json-script", "script": "test" },
        { "type": "static", "value": "npm run test" }
      ]
    },
    {
      "key": "FE_FORMAT",
      "label": "Frontend format command",
      "scope": "fe",
      "detect": [
        { "type": "package-json-script", "script": "format" },
        { "type": "static", "value": "npx prettier --write ." }
      ]
    },
    {
      "key": "FE_LINT",
      "label": "Frontend lint command",
      "scope": "fe",
      "detect": [
        { "type": "package-json-script", "script": "lint" },
        { "type": "static", "value": "npx nx lint" }
      ]
    },
    {
      "key": "BE_SLN",
      "label": "Backend .NET solution file (path)",
      "scope": "be",
      "required": true,
      "detect": [
        { "type": "glob-first-path", "pattern": "**/*.sln" }
      ]
    },
    {
      "key": "BE_NAMESPACE",
      "label": "Backend root namespace",
      "scope": "be",
      "required": true,
      "detect": [
        { "type": "regex-capture-from-files", "glob": "**/*.csproj", "pattern": "<RootNamespace>([^<]+)</RootNamespace>" },
        { "type": "derive", "from": "BE_SLN", "rule": "basename-no-ext" }
      ]
    },
    {
      "key": "BE_API_PROJECT",
      "label": "Backend API project path (directory)",
      "scope": "be",
      "required": true,
      "detect": [
        { "type": "glob-first-path", "pattern": "**/*.Api/*.csproj" },
        { "type": "glob-first-path", "pattern": "**/Program.cs" }
      ]
    },
    {
      "key": "BE_BUILD",
      "label": "Backend build command",
      "scope": "be",
      "detect": [
        { "type": "from-variable", "template": "dotnet build {BE_SLN}" },
        { "type": "static", "value": "dotnet build" }
      ]
    },
    {
      "key": "BE_TEST",
      "label": "Backend test command",
      "scope": "be",
      "detect": [
        { "type": "from-variable", "template": "dotnet test {BE_SLN}" },
        { "type": "static", "value": "dotnet test" }
      ]
    },
    {
      "key": "BE_RUN",
      "label": "Backend dev run command",
      "scope": "be",
      "detect": [
        { "type": "from-variable", "template": "dotnet run --project {BE_API_PROJECT}" },
        { "type": "static", "value": "dotnet run" }
      ]
    },
    {
      "key": "BE_FORMAT",
      "label": "Backend format command",
      "scope": "be",
      "detect": [
        { "type": "glob-present", "pattern": ".config/dotnet-tools.json", "value_when_true": "dotnet csharpier ." },
        { "type": "static", "value": "dotnet format" }
      ]
    },
    {
      "key": "DB_START",
      "label": "Local database start command",
      "scope": "be",
      "detect": [
        { "type": "docker-compose-service", "service_hint": "postgres|mysql|mariadb|mssql" }
      ]
    },
    {
      "key": "MIGRATION",
      "label": "EF Core migration add command template",
      "scope": "be",
      "detect": [
        { "type": "from-variable", "template": "dotnet ef migrations add <Name> --project {BE_API_PROJECT}/../{BE_NAMESPACE}.Migrations --startup-project {BE_API_PROJECT}" },
        { "type": "static", "value": "dotnet ef migrations add <Name>" }
      ]
    },
    {
      "key": "E2E_CMD",
      "label": "End-to-end test command",
      "scope": "fe",
      "detect": [
        { "type": "glob-present", "pattern": "**/playwright.config.*", "value_when_true": "npx playwright test" },
        { "type": "glob-present", "pattern": "**/cypress.config.*", "value_when_true": "npx cypress run" }
      ]
    }
  ]
}
